# FastAPI app metadata/logging
SERVICE_NAME=a2ui-agui-agent-shared-backend
LOG_LEVEL=INFO

# Comma-separated browser origins allowed to call the backend directly.
# The default frontend dev server is http://localhost:3000.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:8301

# Pydantic AI model id.
# OpenRouter models use the openrouter:<provider>/<model> format.
PYDANTIC_AI_MODEL=openrouter:openai/gpt-oss-120b

# Required for real agent runs.
# Get this from OpenRouter and keep the real value only in .env.
OPENROUTER_API_KEY=
